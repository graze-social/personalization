# Graze API Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Redis connection URL for like graph and caching
REDIS_URL=redis://localhost:6379

# Optional: Redis URL for post-render / request logging (log_tasks queue). When unset, skipped quietly.
# REDIS_REQUESTS_LOGGER=redis://localhost:6379

# ClickHouse host for interactions logging and algorithm posts
CLICKHOUSE_HOST=localhost

# ClickHouse password (required for cloud deployments)
CLICKHOUSE_PASSWORD=

# =============================================================================
# HTTP Server Configuration
# =============================================================================

# Host to bind the HTTP server to (default: 0.0.0.0)
# HTTP_HOST=0.0.0.0

# Port to bind the HTTP server to (default: 8080)
# HTTP_PORT=8080

# Public hostname the service is running on (for feed generator DID resolution)
# HTTP_EXTERNAL=

# Number of HTTP worker threads (default: 4)
# HTTP_WORKERS=4

# =============================================================================
# Metrics Configuration
# =============================================================================

# Enable Prometheus metrics endpoint (default: true)
# METRICS_ENABLED=true

# Port for the metrics server (default: 9090)
# METRICS_PORT=9090

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection pool size (default: 100)
# REDIS_POOL_SIZE=100

# Maximum retries when connecting to Redis (default: 10)
# REDIS_CONNECT_MAX_RETRIES=10

# Initial delay in milliseconds between Redis connection retries (default: 500)
# REDIS_CONNECT_INITIAL_DELAY_MS=500

# =============================================================================
# ClickHouse Configuration
# =============================================================================

# ClickHouse HTTP port (default: 8123)
# CLICKHOUSE_PORT=8123

# ClickHouse username (default: default)
# CLICKHOUSE_USER=default

# ClickHouse database name (default: default)
# CLICKHOUSE_DATABASE=default

# Use TLS for ClickHouse connections (default: false)
# CLICKHOUSE_SECURE=false

# =============================================================================
# Feed Generator Configuration
# =============================================================================

# DID for the feed generator service (default: did:web:labs.graze.social)
# FEED_GENERATOR_DID=did:web:labs.graze.social

# =============================================================================
# Personalization Algorithm Configuration
# =============================================================================

# Enable inverted algorithm for scoring posts (default: true)
# INVERTED_ALGORITHM_ENABLED=true

# Minimum likes on a post to use inverted algorithm (default: 10)
# INVERTED_MIN_POST_LIKES=10

# Maximum likers to sample per post in inverted algorithm (default: 30)
# INVERTED_MAX_LIKERS_PER_POST=30

# Maximum posts to score in inverted algorithm, 0 for unlimited (default: 0)
# INVERTED_MAX_POSTS_TO_SCORE=0

# Minimum overlapping co-likers required for scoring (default: 1)
# MIN_OVERLAPPING_COLIKERS=1

# Enable LinkLonk weight normalization (default: true)
# LINKLONK_NORMALIZATION_ENABLED=true

# =============================================================================
# Liker Cache Configuration
# =============================================================================

# Enable in-memory cache for post likers (default: true)
# LIKER_CACHE_ENABLED=true

# Maximum entries in liker cache (default: 400000)
# LIKER_CACHE_MAX_SIZE=400000

# TTL for liker cache entries in seconds (default: 600)
# LIKER_CACHE_TTL_SECONDS=600

# Number of hot posts to prewarm in cache (default: 10000)
# LIKER_CACHE_PREWARM_COUNT=10000

# =============================================================================
# Local Algorithm Cache Configuration
# =============================================================================

# TTL for local algo cache entries in seconds (default: 120)
# LOCAL_ALGO_CACHE_TTL_SECONDS=120

# Maximum algorithms to cache locally (default: 100)
# LOCAL_ALGO_CACHE_MAX_ALGOS=100

# =============================================================================
# Seen Posts Bloom Filter Configuration
# =============================================================================

# Enable bloom filter for tracking seen posts (default: true)
# SEEN_BLOOM_ENABLED=true

# Expected items per user in bloom filter (default: 10000)
# SEEN_BLOOM_EXPECTED_ITEMS=10000

# Target false positive rate for bloom filter (default: 0.01)
# SEEN_BLOOM_FALSE_POSITIVE_RATE=0.01

# Maximum users to track in bloom filter cache (default: 20000)
# SEEN_BLOOM_MAX_USERS=20000

# =============================================================================
# Seen Posts Redis Configuration
# =============================================================================

# Enable tracking seen posts in Redis (default: true)
# SEEN_POSTS_ENABLED=true

# TTL for seen posts in hours (default: 48)
# SEEN_POSTS_TTL_HOURS=48

# =============================================================================
# Trending Posts Configuration
# =============================================================================

# Maximum trending posts to cache (default: 500)
# TRENDING_POSTS_LIMIT=500

# TTL for trending posts cache in hours (default: 1)
# TRENDING_POSTS_TTL_HOURS=1

# Recency decay half-life in hours for trending score (default: 24.0)
# TRENDING_RECENCY_DECAY_HOURS=24.0

# =============================================================================
# Fallback Tranches Configuration
# =============================================================================

# Ratio of personalized content in feed (default: 0.80)
# FALLBACK_PERSONALIZATION_RATIO=0.80

# Ratio of popular content in fallback mix (default: 0.34)
# FALLBACK_POPULAR_RATIO=0.34

# Ratio of trending content in fallback mix (default: 0.33)
# FALLBACK_TRENDING_RATIO=0.33

# Ratio of discovery content in fallback mix (default: 0.33)
# FALLBACK_DISCOVERY_RATIO=0.33

# Stagger factor for interleaving tranches (default: 0.3)
# FALLBACK_STAGGER_FACTOR=0.3

# Maximum popular posts to cache (default: 500)
# POPULAR_POSTS_LIMIT=500

# Decay half-life in hours for popular posts (default: 48.0)
# POPULAR_DECAY_HOURS=48.0

# Minimum likes for popular post eligibility (default: 10)
# POPULAR_MIN_LIKES=10

# Window in hours for velocity calculation (default: 6.0)
# VELOCITY_WINDOW_HOURS=6.0

# Minimum likes in window for velocity posts (default: 3)
# VELOCITY_MIN_LIKES=3

# Maximum velocity posts to cache (default: 500)
# VELOCITY_POSTS_LIMIT=500

# Minimum posts for author success scoring (default: 3)
# AUTHOR_SUCCESS_MIN_POSTS=3

# Decay half-life in hours for author success (default: 48.0)
# AUTHOR_SUCCESS_DECAY_HOURS=48.0

# Maximum discovery posts to cache (default: 500)
# DISCOVERY_POSTS_LIMIT=500

# Maximum likes for discovery post eligibility (default: 5)
# DISCOVERY_MAX_POST_LIKES=5

# =============================================================================
# Progressive Blending Configuration
# =============================================================================

# Maximum likes to consider user "cold" (default: 5)
# COLD_USER_MAX_LIKES=5

# Maximum likes to consider user "warm" (default: 20)
# WARM_USER_MAX_LIKES=20

# Trending ratio for cold users (default: 0.8)
# COLD_USER_TRENDING_RATIO=0.8

# Trending ratio for warm users (default: 0.5)
# WARM_USER_TRENDING_RATIO=0.5

# =============================================================================
# Feed Cache Configuration
# =============================================================================

# Enable feed skeleton caching (default: true)
# FEED_CACHE_ENABLED=true

# TTL for feed cache entries in seconds (default: 600)
# FEED_CACHE_TTL_SECONDS=600

# Maximum feeds to cache per user (default: 1000)
# FEED_CACHE_SIZE=1000

# Threshold for triggering background refresh in seconds (default: 120)
# FEED_CACHE_STALE_THRESHOLD_SECONDS=120

# Batch size for feed cache operations (default: 300)
# FEED_CACHE_BATCH_SIZE=300

# =============================================================================
# Co-liker Pre-computation Configuration
# =============================================================================

# Enable co-liker pre-computation (default: true)
# COLIKER_ENABLED=true

# TTL for co-liker cache in seconds (default: 21600)
# COLIKER_TTL_SECONDS=21600

# Threshold for triggering co-liker refresh in seconds (default: 3600)
# COLIKER_REFRESH_THRESHOLD_SECONDS=3600

# Maximum co-liker sources to consider (default: 1000)
# COLIKER_MAX_SOURCES=1000

# =============================================================================
# Author Affinity Configuration
# =============================================================================

# Enable author-level affinity scoring (default: true)
# AUTHOR_AFFINITY_ENABLED=true

# Maximum liked authors to track per user (default: 500)
# MAX_LIKED_AUTHORS_PER_USER=500

# Maximum likers to track per author (default: 1000)
# MAX_LIKERS_PER_AUTHOR=1000

# Maximum authors to consider for affinity (default: 100)
# AUTHOR_AFFINITY_MAX_AUTHORS=100

# Maximum co-likers for author affinity (default: 300)
# AUTHOR_AFFINITY_MAX_COLIKERS=300

# Maximum likers per author for affinity scoring (default: 100)
# AUTHOR_AFFINITY_MAX_LIKERS_PER_AUTHOR=100

# Time window in hours for author affinity (default: 168)
# AUTHOR_AFFINITY_TIME_WINDOW_HOURS=168

# TTL for author affinity cache in seconds (default: 3600)
# AUTHOR_AFFINITY_TTL_SECONDS=3600

# Threshold for triggering author affinity refresh in seconds (default: 600)
# AUTHOR_AFFINITY_REFRESH_THRESHOLD_SECONDS=600

# Maximum posts to score for author affinity (default: 500)
# AUTHOR_AFFINITY_MAX_POSTS_TO_SCORE=500

# Minimum author likes for affinity consideration (default: 2)
# AUTHOR_AFFINITY_MIN_AUTHOR_LIKES=2

# =============================================================================
# Author Diversity Configuration
# =============================================================================

# Enable author diversity in feed results (default: true)
# DIVERSITY_ENABLED=true

# Maximum posts per author in results (default: 3)
# MAX_POSTS_PER_AUTHOR=3

# Diminishing factor for repeated authors (default: 0.5)
# AUTHOR_DIMINISHING_FACTOR=0.5

# MMR lambda for diversity vs relevance tradeoff (default: 0.3)
# DIVERSITY_MMR_LAMBDA=0.3

# =============================================================================
# Personalization Defaults
# =============================================================================

# Threshold for triggering stale result refresh in seconds (default: 60)
# STALE_REFRESH_THRESHOLD_SECONDS=60

# Maximum user likes to consider (default: 750)
# DEFAULT_MAX_USER_LIKES=750

# Maximum sources per post (default: 100)
# DEFAULT_MAX_SOURCES_PER_POST=100

# Minimum co-likes required (default: 1)
# DEFAULT_MIN_CO_LIKES=1

# Time window in hours for like consideration (default: 48.0)
# DEFAULT_TIME_WINDOW_HOURS=48.0

# Recency half-life in hours (default: 24.0)
# DEFAULT_RECENCY_HALF_LIFE_HOURS=24.0

# Specificity power for scoring (default: 1.0)
# DEFAULT_SPECIFICITY_POWER=1.0

# Popularity power for scoring (default: 0.6)
# DEFAULT_POPULARITY_POWER=0.6

# Maximum weight for co-liker contribution (default: 0.000001)
# MAX_COLIKER_WEIGHT=0.000001

# Maximum posts to sample for prove mode, 0 for disabled (default: 0)
# PROVE_MAX_POSTS_TO_SAMPLE=0

# =============================================================================
# Interactions Logging Configuration
# =============================================================================

# Enable logging interactions to ClickHouse (default: true)
# INTERACTIONS_LOGGING_ENABLED=true
# INTERACTIONS_BATCH_INTERVAL_MS=3000
# INTERACTIONS_BATCH_SIZE=200
# INTERACTIONS_QUEUE_CAPACITY=5000

# =============================================================================
# Feed Access Sync Configuration
# =============================================================================

# Enable feed access sync from ClickHouse (default: true)
# FEED_ACCESS_SYNC_ENABLED=true

# =============================================================================
# Read-Only Mode Configuration
# =============================================================================

# Enable read-only mode for shadow traffic testing (default: false)
# READ_ONLY_MODE=false

# =============================================================================
# Admin API Authentication
# =============================================================================

# When set, admin endpoints (feeds, special-posts, etc.) require this key via Authorization: Bearer or X-API-Key.
# Must match PERSONALIZATION_ADMIN_API_KEY in feed-processor. Unset = auth disabled.
# ADMIN_API_KEY=your-admin-api-key
# FEED_GENERATOR_DID=did:web:beta.graze.social

# =============================================================================
# Audit Configuration
# =============================================================================

# Enable audit logging (default: false)
# AUDIT_ENABLED=false

# Audit all users instead of sampling (default: false)
# AUDIT_ALL_USERS=false

# Sample rate for audit logging (default: 0.0)
# AUDIT_SAMPLE_RATE=0.0

# Log full scoring breakdown in audits (default: false)
# AUDIT_LOG_FULL_BREAKDOWN=false

# Maximum contributors to log in audit (default: 10)
# AUDIT_MAX_CONTRIBUTORS=10
