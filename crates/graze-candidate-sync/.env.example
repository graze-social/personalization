# Graze Candidate Sync Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Redis connection URL for storing algorithm posts and fallback tranches
REDIS_URL=redis://localhost:6379

# ClickHouse host for querying algorithm posts
CLICKHOUSE_HOST=localhost

# ClickHouse password (required for cloud deployments)
CLICKHOUSE_PASSWORD=

# =============================================================================
# Metrics Configuration
# =============================================================================

# Port for the metrics server, 0 to disable (default: 0)
# METRICS_PORT=0

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection pool size (default: 100)
# REDIS_POOL_SIZE=100

# Maximum retries when connecting to Redis (default: 10)
# REDIS_CONNECT_MAX_RETRIES=10

# Initial delay in milliseconds between Redis connection retries (default: 500)
# REDIS_CONNECT_INITIAL_DELAY_MS=500

# =============================================================================
# ClickHouse Configuration
# =============================================================================

# ClickHouse HTTP port (default: 8123)
# CLICKHOUSE_PORT=8123

# ClickHouse database name (default: graze)
# CLICKHOUSE_DATABASE=graze

# ClickHouse username (default: default)
# CLICKHOUSE_USER=default

# Use TLS for ClickHouse connections (default: false)
# CLICKHOUSE_SECURE=false

# =============================================================================
# Feed Access Rolling Sync Configuration
# =============================================================================

# Enable feed access sync from ClickHouse (default: true)
# FEED_ACCESS_SYNC_ENABLED=true

# Interval between feed access scans in seconds (default: 300)
# FEED_ACCESS_SCAN_INTERVAL_SECONDS=300

# Time window for feed access lookback in seconds (default: 86400)
# FEED_ACCESS_WINDOW_SECONDS=86400

# =============================================================================
# Sync Rate Limiting Configuration
# =============================================================================

# Minimum seconds between syncs for same algorithm (default: 300)
# SYNC_RATE_LIMIT_SECONDS=300

# Threshold in minutes to consider sync stale (default: 30)
# SYNC_REFRESH_THRESHOLD_MINUTES=30

# Delay between batches in milliseconds (default: 10)
# SYNC_BATCH_DELAY_MS=10

# Yield to scheduler every N batches (default: 10)
# SYNC_YIELD_EVERY_N_BATCHES=10

# =============================================================================
# Algorithm Post Sync Configuration
# =============================================================================

# Preferred maximum age in hours for algorithm posts (default: 48)
# SYNC_PREFERRED_MAX_AGE_HOURS=48

# Fallback maximum age in hours if preferred returns too few (default: 72)
# SYNC_FALLBACK_MAX_AGE_HOURS=72

# Minimum posts required before using fallback age (default: 1000)
# SYNC_MINIMUM_POSTS=1000

# Maximum posts to sync per algorithm (default: 25000)
# ALGO_POSTS_LIMIT=25000

# TTL for algorithm posts in Redis in hours (default: 4)
# ALGO_POSTS_TTL_HOURS=4

# =============================================================================
# Algo Likers Sync Configuration
# =============================================================================

# Enable syncing likers for algorithm posts (default: true)
# ALGO_LIKERS_ENABLED=true

# Batch size for likers sync operations (default: 200)
# ALGO_LIKERS_BATCH_SIZE=200

# =============================================================================
# Trending Tranche Configuration
# =============================================================================

# Recency decay half-life in hours for trending score (default: 6.0)
# TRENDING_RECENCY_DECAY_HOURS=6.0

# Maximum trending posts to compute (default: 1000)
# TRENDING_POSTS_LIMIT=1000

# TTL for trending posts in Redis in hours (default: 4)
# TRENDING_POSTS_TTL_HOURS=4

# =============================================================================
# Popular Tranche Configuration
# =============================================================================

# Decay half-life in hours for popular score (default: 168.0)
# POPULAR_DECAY_HOURS=168.0

# Minimum likes for popular post eligibility (default: 10)
# POPULAR_MIN_LIKES=10

# Maximum popular posts to compute (default: 500)
# POPULAR_POSTS_LIMIT=500

# =============================================================================
# Velocity Tranche Configuration
# =============================================================================

# Time window in hours for velocity calculation (default: 6.0)
# VELOCITY_WINDOW_HOURS=6.0

# Minimum likes in window for velocity eligibility (default: 5)
# VELOCITY_MIN_LIKES=5

# Maximum velocity posts to compute (default: 300)
# VELOCITY_POSTS_LIMIT=300

# =============================================================================
# Discovery Tranche Configuration
# =============================================================================

# Decay half-life in hours for author success (default: 168.0)
# AUTHOR_SUCCESS_DECAY_HOURS=168.0

# Minimum posts for author success scoring (default: 3)
# AUTHOR_SUCCESS_MIN_POSTS=3

# Maximum likes for discovery post eligibility (default: 5)
# DISCOVERY_MAX_POST_LIKES=5

# Maximum discovery posts to compute (default: 500)
# DISCOVERY_POSTS_LIMIT=500
