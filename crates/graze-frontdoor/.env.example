# Graze Frontdoor Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# URL of the feed service backend (handles filtered feed endpoints)
FEED_SERVICE_HOST=http://localhost:8080

# URL of the labs service backend (handles all other requests)
LABS_SERVICE_HOST=http://localhost:8082

# =============================================================================
# HTTP Server Configuration
# =============================================================================

# Host to bind the proxy server to (default: 0.0.0.0)
# HTTP_HOST=0.0.0.0

# Port to bind the proxy server to (default: 8081)
# HTTP_PORT=8081

# =============================================================================
# Metrics Configuration
# =============================================================================

# Port for the metrics server (default: 9091)
# METRICS_PORT=9091

# =============================================================================
# Request Configuration
# =============================================================================

# Timeout for proxied requests in seconds (default: 30)
# REQUEST_TIMEOUT_SECONDS=30

# Connection timeout in seconds (default: 5)
# CONNECT_TIMEOUT_SECONDS=5

# =============================================================================
# DID Allowlist Configuration
# =============================================================================

# Redis URL for loading allowed identities (optional, enables dynamic allowlist)
# REDIS_URL=redis://localhost:6379

# Interval to refresh allowlist from Redis in seconds (default: 60)
# ALLOWLIST_REFRESH_SECONDS=60

# Comma-separated list of allowed DIDs (fallback if Redis unavailable)
# ALLOWED_DIDS=did:plc:example1,did:plc:example2
