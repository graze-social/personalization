# Graze Like Streamer Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Redis connection URL for storing the like graph
REDIS_URL=redis://localhost:6379

# =============================================================================
# Metrics Configuration
# =============================================================================

# Port for the metrics server, 0 to disable (default: 0)
# METRICS_PORT=0

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection pool size (default: 100)
# REDIS_POOL_SIZE=100

# Maximum retries when connecting to Redis (default: 10)
# REDIS_CONNECT_MAX_RETRIES=10

# Initial delay in milliseconds between Redis connection retries (default: 500)
# REDIS_CONNECT_INITIAL_DELAY_MS=500

# =============================================================================
# Jetstream Configuration
# =============================================================================

# Jetstream WebSocket URL for consuming likes (default: wss://jetstream2.us-west.bsky.network/subscribe)
# JETSTREAM_URL=wss://jetstream2.us-west.bsky.network/subscribe

# Read timeout for Jetstream in seconds (default: 45)
# JETSTREAM_READ_TIMEOUT_SECONDS=45

# Timeout before considering Jetstream connection stale in seconds (default: 60)
# JETSTREAM_STALE_TIMEOUT_SECONDS=60

# =============================================================================
# Like Graph Configuration
# =============================================================================

# TTL for like data in days (default: 8)
# LIKE_TTL_DAYS=8

# Batch size for Redis write operations (default: 5000)
# LIKE_BATCH_SIZE=5000

# Interval between batch flushes in milliseconds (default: 5000)
# LIKE_BATCH_INTERVAL_MS=5000

# Interval for refreshing TTLs on existing keys in seconds (default: 3600)
# LIKE_TTL_REFRESH_INTERVAL_SECONDS=3600

# Maximum likes to store per user (default: 5000)
# MAX_LIKES_PER_USER=5000

# Maximum likers to store per post (default: 10000)
# MAX_LIKERS_PER_POST=10000

# =============================================================================
# Author-Level Affinity Configuration
# =============================================================================

# Maximum liked authors to track per user (default: 500)
# MAX_LIKED_AUTHORS_PER_USER=500

# Maximum likers to track per author (default: 1000)
# MAX_LIKERS_PER_AUTHOR=1000

# =============================================================================
# Bot Filtering Configuration
# =============================================================================

# Enable bot filtering (default: true)
# BOT_FILTER_ENABLED=true

# Likes per day threshold to flag as bot (default: 5000)
# BOT_LIKE_THRESHOLD=5000

# Interval to refresh bot cache in seconds (default: 300)
# BOT_CACHE_REFRESH_SECONDS=300

# TTL for bot log entries in days (default: 30)
# BOT_LOG_TTL_DAYS=30

# =============================================================================
# Cleanup Worker Configuration
# =============================================================================

# Enable background cleanup worker (default: true)
# CLEANUP_WORKER_ENABLED=true

# Interval between cleanup runs in hours (default: 8)
# CLEANUP_INTERVAL_HOURS=8

# =============================================================================
# Algorithm Feature Flags
# =============================================================================

# Enable LinkLonk weight normalization (default: true)
# LINKLONK_NORMALIZATION_ENABLED=true
